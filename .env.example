# VICIdial iframe login behavior (set to no-confirmation by default)
VICI_SESSION_IFRAME_AGENT_API_ONLY=true
VICI_SESSION_IFRAME_CONFIRM_NON_AGENT_LIVE=false
# Optional: keep false unless you explicitly want to skip all Non-Agent checks
# VICI_SESSION_SKIP_NON_AGENT_LIVE_CHECK=false
APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# When APP_URL is https, set SESSION_SECURE_COOKIE=true or the session cookie may not be sent (419 on login).
# SESSION_SECURE_COOKIE=

# Trust proxies (e.g. nginx/Cloudflare) if needed: see Laravel TrustProxies / bootstrap configuration.

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Real-time broadcasting (Laravel Reverb / Pusher)
# Set BROADCAST_CONNECTION=reverb or pusher for WebSocket real-time
# REVERB_APP_ID=
# REVERB_APP_KEY=
# REVERB_APP_SECRET=
# REVERB_HOST=127.0.0.1
# REVERB_PORT=6001
# REVERB_SCHEME=http
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# VICIdial
# VICI_DB_HOST=127.0.0.1
# VICI_API_URL=http://vici/agc/api.php
# VICI_NON_AGENT_API_URL=http://vici/non_agent_api.php
# VICI_SOURCE=crm_tracker
# VICI_SESSION_STATUS_POLL_SECONDS=15
# VICI_AUTO_BOOTSTRAP=false   # Global enable; per-user also needs auto_vici_login on users table
# VICI_SESSION_IFRAME_AGENT_API_ONLY=false  # Session verify/status skip Non-Agent; trust iframe + one verify POST
# VICI_SESSION_IFRAME_CONFIRM_NON_AGENT_LIVE=true # If iframe-only: when Non-Agent API exists, verify checks live_agents
# VICI_SESSION_SKIP_NON_AGENT_LIVE_CHECK=        # Empty = auto true in local/development, false elsewhere; set true|false to override
# VICI_REQUIRE_VICIDIAL_SESSION_BEFORE_DIAL=true # Block /api/call/dial until vicidial_agent_sessions is ready/paused/in_call
# VICI_AGENT_CAMPAIGNS_LOOKUP=true          # GET agent-campaigns: Non-Agent API agent_campaigns + DB fallback
# VICI_VERIFY_SSL=true       # Set to false for on-premise self-signed SSL setups

# Asterisk AMI
# ASTERISK_AMI_HOST=127.0.0.1
# ASTERISK_AMI_PORT=5038
# ASTERISK_AMI_USERNAME=cron
# ASTERISK_AMI_SECRET=
# ASTERISK_AMI_TIMEOUT=5
# ASTERISK_AMI_READ_TIMEOUT=5000
# ASTERISK_AMI_WEBHOOK_SECRET=  # Optional; validate webhook POSTs via X-Webhook-Secret header
# AMI_LISTENER_RECONNECT_DELAY=5       # Seconds before reconnect attempt
# AMI_LISTENER_MAX_RECONNECT_DELAY=60  # Max backoff ceiling in seconds

# Asterisk outbound trunk (chan_sip peer name in sip.conf)
# ASTERISK_GOIP_TRUNK=goip-trunk

# ViciDial Agent Events Push
# Configure in ViciDial System Settings -> Agent Push Events = 1
# Agent Push URL (using get2post.php on the ViciDial server):
#   get2post.php?HTTPURLTOPOST=http://CRM_IP:8000/api/webhooks/vicidial-events?user=--A--user--B--&event=--A--event--B--&message=--A--message--B--&lead_id=--A--lead_id--B--&counter=--A--counter--B--
# VICIDIAL_EVENTS_WEBHOOK_SECRET=  # Optional shared secret for webhook validation

# Asterisk WebRTC / SIP (SIP.js browser agents)
# ASTERISK_AGENT_CHANNEL=SIP   # SIP-only mode; PJSIP is not supported by this CRM telephony flow
# ASTERISK_WS_URL=wss://YOUR_ASTERISK_IP:8089/ws
# SIP_DOMAIN=YOUR_ASTERISK_IP
# STUN_SERVER=stun.l.google.com:19302
# ICE_SERVERS=[]
# SIP_REGISTER_TIMEOUT=60
# SIP_NO_ANSWER_TIMEOUT=45
VITE_ASTERISK_WS_URL="${ASTERISK_WS_URL}"
VITE_SIP_DOMAIN="${SIP_DOMAIN}"
VITE_STUN_SERVER="${STUN_SERVER}"
